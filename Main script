local TabMisc = Window:CreateTab("Misc", 4483362458)

TabMisc:CreateSection("Utilities")

TabMisc:CreateButton({
    Name     = "Rejoin Server",
    Callback = function()
        TeleportService:Teleport(game.PlaceId, LocalPlayer)
    end,
})

TabMisc:CreateButton({
    Name     = "Copy Player List",
    Callback = function()
        local names = {}
        for _, p in ipairs(Players:GetPlayers()) do
            table.insert(names, p.Name .. " (Ping: " .. tostring(p:GetNetworkPing and math.floor(p:GetNetworkPing()*1000) or "?") .. "ms)")
        end
        local result = table.concat(names, "\n")
        pcall(setclipboard, result)
        notify("Copied!", "Player list copied to clipboard.", 3)
    end,
})

TabMisc:CreateButton({
    Name     = "Refresh All ESPs",
    Callback = function()
        if State.PlayerESP  then disablePlayerESP();  enablePlayerESP()  end
        if State.MonsterESP then disableMonsterESP(); enableMonsterESP() end
        if State.ItemESP    then disableItemESP();    enableItemESP()    end
        notify("ESP", "All ESPs refreshed.", 2)
    end,
})

TabMisc:CreateSection("Info")

TabMisc:CreateLabel("Script by RscriptsX")
