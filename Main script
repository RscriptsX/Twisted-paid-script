local function enableFly()
    local root = getRoot()
    if not root then return end
    State.Fly = true
    
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    bv.Velocity = Vector3.zero
    bv.Parent = root
    
    local bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
    bg.P = 1e6
    bg.CFrame = root.CFrame
    bg.Parent = root
    
    Connections.fly = RunService.Heartbeat:Connect(function()
        if not State.Fly then bv:Destroy(); bg:Destroy(); Connections.fly:Disconnect(); return end
        local root = getRoot()
        if not root then return end
        
        local vel = Vector3.zero
        local cam = Workspace.CurrentCamera
        local speed = State.FlySpeed
        
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then vel = vel + cam.CFrame.LookVector * speed end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then vel = vel - cam.CFrame.LookVector * speed end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then vel = vel - cam.CFrame.RightVector * speed end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then vel = vel + cam.CFrame.RightVector * speed end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then vel = vel + Vector3.new(0, speed, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then vel = vel - Vector3.new(0, speed, 0) end
        
        bv.Velocity = vel
        bg.CFrame = cam.CFrame
    end)
end

local function enableCarFly()
    State.CarFly = true
    Connections.carfly = RunService.Heartbeat:Connect(function()
        if not State.CarFly then Connections.carfly:Disconnect(); return end
        local char = getChar()
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or not hum.SeatPart then return end
        
        local car = hum.SeatPart.Parent
        local primary = car:IsA("Model") and car.PrimaryPart or hum.SeatPart
        if not primary then return end
        
        local vel = Vector3.zero
        local cam = Workspace.CurrentCamera
        local speed = State.FlySpeed * 1.5
        
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then vel = vel + cam.CFrame.LookVector * speed end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then vel = vel - cam.CFrame.LookVector * speed end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then vel = vel - cam.CFrame.RightVector * speed end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then vel = vel + cam.CFrame.RightVector * speed end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then vel = vel + Vector3.new(0, speed, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then vel = vel - Vector3.new(0, speed, 0) end
        
        local bodyVel = primary:FindFirstChild("RX_CarFlyVel")
        if not bodyVel then
            bodyVel = Instance.new("BodyVelocity")
            bodyVel.Name = "RX_CarFlyVel"
            bodyVel.MaxForce = Vector3.new(1e9, 1e9, 1e9)
            bodyVel.Parent = primary
        end
        bodyVel.Velocity = vel
    end)
end

local function getCurrentCar()
    local char = getChar()
    if not char then return nil end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or not hum.SeatPart then return nil end
    return hum.SeatPart.Parent
end

local carSpeedTimer = 0
Connections.carMods = RunService.Heartbeat:Connect(function(dt)
    carSpeedTimer = carSpeedTimer + dt
    if carSpeedTimer < 0.2 then return end
    carSpeedTimer = 0
    
    local car = getCurrentCar()
    if not car then return end
    
    if State.CarSpeedMod then
        local seat = car:FindFirstChildOfClass("VehicleSeat")
        if seat then seat.MaxSpeed = State.CarSpeed end
    end
    
    if State.CarAccelMod then
        local seat = car:FindFirstChildOfClass("VehicleSeat")
        if seat then seat.Torque = State.CarAccel end
    end
    
    if State.CarWindThreshMod then
        for _, v in ipairs(car:GetDescendants()) do
            if v:IsA("NumberValue") and v.Name:lower():find("wind") then
                v.Value = State.CarWindThresh
            end
        end
    end
    
    if State.InfiniteFuel then
        for _, v in ipairs(car:GetDescendants()) do
            if v:IsA("NumberValue") and v.Name:lower():find("fuel") then
                v.Value = v.MaxValue or 100
            end
        end
    end
end)

