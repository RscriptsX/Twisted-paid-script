local TabTeleport = Window:CreateTab("Teleport", 4483362458)

TabTeleport:CreateSection("Player Teleport")

local function getPlayerNames()
    local names = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then table.insert(names, p.Name) end
    end
    return #names > 0 and names or {"No other players"}
end

local playerDropdown = TabTeleport:CreateDropdown({
    Name = "Select Player",
    Options = getPlayerNames(),
    CurrentOption = {getPlayerNames()[1]},
    MultipleOptions = false,
    Flag = "TeleportTarget",
    Callback = function() end,
})

TabTeleport:CreateButton({
    Name = "Teleport to Player",
    Callback = function()
        local sel = Rayfield.Flags.TeleportTarget
        local target = sel and sel[1]
        if not target or target == "No other players" then
            notify("Teleport", "No player selected.", 3)
            return
        end
        local root = getRoot()
        local tp = Players:FindFirstChild(target)
        if root and tp and tp.Character then
            local tr = tp.Character:FindFirstChild("HumanoidRootPart")
            if tr then
                root.CFrame = tr.CFrame + Vector3.new(0, 0, 3)
                notify("Teleport", "Teleported to " .. target, 3)
            end
        end
    end,
})

TabTeleport:CreateButton({
    Name = "Refresh Player List",
    Callback = function()
        playerDropdown:Refresh(getPlayerNames(), false)
        notify("Teleport", "Player list refreshed.", 2)
    end,
})

TabTeleport:CreateSection("World Teleport")

TabTeleport:CreateButton({
    Name = "Teleport to Spawn",
    Callback = function()
        local root = getRoot()
        if not root then return end
        for _, v in ipairs(Workspace:GetDescendants()) do
            if v:IsA("SpawnLocation") then
                root.CFrame = v.CFrame + Vector3.new(0, 5, 0)
                notify("Teleport", "Teleported to Spawn.", 2)
                return
            end
        end
        notify("Teleport", "No spawn found.", 3)
    end,
})

TabTeleport:CreateButton({
    Name = "Teleport to Nearest Item",
    Callback = function()
        local root = getRoot()
        if not root then return end
        local closest, closestDist = nil, math.huge
        for _, fn in ipairs(ITEM_FOLDERS) do
            local folder = Workspace:FindFirstChild(fn)
            if folder then
                for _, obj in ipairs(folder:GetChildren()) do
                    local part = obj:IsA("BasePart") and obj or obj:FindFirstChildOfClass("BasePart")
                    if part then
                        local d = (root.Position - part.Position).Magnitude
                        if d < closestDist then closestDist = d; closest = part end
                    end
                end
            end
        end
        if closest then
            root.CFrame = CFrame.new(closest.Position + Vector3.new(0, 4, 0))
            notify("Teleport", "Teleported to nearest item.", 2)
        else
            notify("Teleport", "No items found.", 3)
        end
    end,
})

TabTeleport:CreateButton({
    Name = "Teleport to Nearest Monster",
    Callback = function()
        local root = getRoot()
        if not root then return end
        local closest, closestDist = nil, math.huge
        for _, fn in ipairs(MONSTER_FOLDERS) do
            local folder = Workspace:FindFirstChild(fn)
            if folder then
                for _, model in ipairs(folder:GetChildren()) do
                    if model:IsA("Model") then
                        local part = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChildOfClass("BasePart")
                        if part then
                            local d = (root.Position - part.Position).Magnitude
                            if d < closestDist then closestDist = d; closest = part end
                        end
                    end
                end
            end
        end
        if closest then
            root.CFrame = CFrame.new(closest.Position + Vector3.new(5, 0, 5))
            notify("Teleport", "Teleported near monster.", 2)
        else
            notify("Teleport", "No monsters found.", 3)
