local function findTornadoes()
    local tornadoes = {}
    for _, child in ipairs(Workspace:GetChildren()) do
        local name = child.Name:lower()
        if name:find("tornado") or name:find("twister") or name:find("vortex") or
           name:find("ef0") or name:find("ef1") or name:find("ef2") or
           name:find("ef3") or name:find("ef4") or name:find("ef5") then
            table.insert(tornadoes, child)
        end
    end
    return tornadoes
end

local function getTornadoData(tornado)
    local data = { ef = "?", windSpeed = 0, moveSpeed = 0, pos = Vector3.zero }
    data.ef = tornado:GetAttribute("EFRating") or tornado:GetAttribute("Rating") or
             tornado:GetAttribute("EF") or "?"
    data.windSpeed = tornado:GetAttribute("WindSpeed") or tornado:GetAttribute("Windspeed") or 0
    data.moveSpeed = tornado:GetAttribute("Speed") or tornado:GetAttribute("MoveSpeed") or 0
    for _, v in ipairs(tornado:GetDescendants()) do
        if v:IsA("NumberValue") or v:IsA("IntValue") then
            local n = v.Name:lower()
            if n:find("wind") then data.windSpeed = v.Value end
            if n:find("ef") or n:find("rating") then data.ef = v.Value end
        end
    end
    local primary = tornado:IsA("Model") and tornado.PrimaryPart or tornado
    data.pos = primary and primary.Position or Vector3.zero
    return data
end

local function getEFColor(ef)
    if ef == 0 or ef == "0" then return Color3.fromRGB(0, 255, 0)
    elseif ef == 1 or ef == "1" then return Color3.fromRGB(255, 255, 0)
    elseif ef == 2 or ef == "2" then return Color3.fromRGB(255, 165, 0)
    elseif ef == 3 or ef == "3" then return Color3.fromRGB(255, 0, 0)
    elseif ef == 4 or ef == "4" then return Color3.fromRGB(139, 0, 0)
    elseif ef == 5 or ef == "5" then return Color3.fromRGB(128, 0, 128)
    else return Color3.fromRGB(200, 200, 200) end
end

local function createTornadoESP(tornado)
    if ESPObjects[tornado] then return end
    local data = getTornadoData(tornado)
    local color = getEFColor(data.ef)
    local h = Instance.new("Highlight")
    h.FillColor = color; h.OutlineColor = color
    h.FillTransparency = 0.5; h.OutlineTransparency = 0
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.Adornee = tornado
    h.Name = "RX_TornadoESP"
    h.Parent = game.CoreGui
    
    local bb = Instance.new("BillboardGui")
    bb.Size = UDim2.new(0, 250, 0, 100)
    bb.StudsOffset = Vector3.new(0, 80, 0)
    bb.AlwaysOnTop = true
    bb.Name = "RX_TornadoLabel"
    bb.Parent = tornado
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    frame.BackgroundTransparency = 0.4
    frame.BorderSizePixel = 0
    frame.Parent = bb
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.GothamBold
    label.TextSize = 14
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextWrapped = true
    label.Parent = frame
    
    local prevPos = data.pos
    local prevTime = tick()
    
    local updateConn = RunService.Heartbeat:Connect(function()
        if not tornado.Parent then
            h:Destroy()
            bb:Destroy()
            updateConn:Disconnect()
            ESPObjects[tornado] = nil
            return
        end
        
        local data = getTornadoData(tornado)
        local root = getRoot()
        local dist = root and (root.Position - data.pos).Magnitude or 0
        local now = tick()
        local moveSpeed = (data.pos - prevPos).Magnitude / math.max(now - prevTime, 0.01)
        prevPos = data.pos
        prevTime = now
        
        local text = "EF" .. tostring(data.ef)
        if State.ShowTornadoWindspeed then text = text .. "\nWind: " .. math.floor(data.windSpeed) .. " mph" end
        if State.ShowTornadoDistance then text = text .. "\nDist: " .. math.floor(dist) .. " studs" end
        label.Text = text
        
        local c = getEFColor(data.ef)
        h.FillColor = c
        h.OutlineColor = c
        label.TextColor3 = c
    end)
    
    ESPObjects[tornado] = { h = h, bb = bb, conn = updateConn }
end

local function disableTornadoESP()
    for tornado, objs in pairs(ESPObjects) do
        if objs.h then objs.h:Destroy() end
        if objs.bb then objs.bb:Destroy() end
        if objs.conn then objs.conn:Disconnect() end
    end
    ESPObjects = {}
end

local function enableTornadoESP()
    disableTornadoESP()
    for _, t in ipairs(findTornadoes()) do createTornadoESP(t) end
end

local function addPlayerESP(player)
    if player == LocalPlayer or ESPObjects[player] then return end
    local h = nil
    local function attach(char)
        if h then h:Destroy() end
        if State.PlayerESP then
            h = Instance.new("Highlight")
            h.FillColor = Color3.fromRGB(0, 150, 255)
            h.OutlineColor = Color3.fromRGB(0, 100, 220)
            h.FillTransparency = 0.4
            h.OutlineTransparency = 0
            h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            h.Adornee = char
            h.Name = "RX_PlayerESP"
            h.Parent = game.CoreGui
        end
    end
    if player.Character then attach(player.Character) end
    local conn = player.CharacterAdded:Connect(function(c) task.wait(0.5); attach(c) end)
    ESPObjects[player] = { h = function() return h end, conn = conn, destroy = function() if h then h:Destroy() end; conn:Disconnect() end }
end

local function enablePlayerESP()
    for _, p in ipairs(Players:GetPlayers()) do addPlayerESP(p) end
    Connections.playerAdded = Players.PlayerAdded:Connect(function(p) task.wait(1); if State.PlayerESP then addPlayerESP(p) end end)
end

local function disablePlayerESP()
    for _, p in ipairs(Players:GetPlayers()) do if ESPObjects[p] then ESPObjects[p].destroy(); ESPObjects[p] = nil end end
    if Connections.playerAdded then Connections.playerAdded:Disconnect() end
end

