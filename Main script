local function makeTornadoBB(parent)
    local existing = parent:FindFirstChild("RX_BB")
    if existing then existing:Destroy() end

    local bb = Instance.new("BillboardGui")
    bb.Name = "RX_BB"
    bb.Size = UDim2.new(0, 270, 0, 80)
    bb.StudsOffset = Vector3.new(0, 120, 0)
    bb.AlwaysOnTop = true
    bb.Parent = parent  -- must be a BasePart

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1,0,1,0)
    bg.BackgroundColor3 = Color3.new(0,0,0)
    bg.BackgroundTransparency = 0.3
    bg.BorderSizePixel = 0
    bg.Parent = bb
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0,6)

    local lbl = Instance.new("TextLabel")
    lbl.Name = "lbl"
    lbl.Size = UDim2.new(1,-8,1,-4)
    lbl.Position = UDim2.new(0,4,0,2)
    lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 13
    lbl.TextColor3 = Color3.new(1,1,1)
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.TextWrapped = true
    lbl.Parent = bg

    return bb, lbl
end

local function addTornadoESP(storm)
    if ESPObjects[storm] then return end

    local h = Instance.new("Highlight")
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.FillTransparency = 0.55
    h.OutlineTransparency = 0
    h.Adornee = storm
    h.Name = "RX_TornadoESP"
    h.Parent = game.CoreGui

    -- Parent billboard to the center BasePart so it renders correctly
    local windFolder = storm:FindFirstChild("wind")
    local center     = windFolder and windFolder:FindFirstChild("center")
    local bbParent   = center or storm.PrimaryPart
    local bb, lbl
    if bbParent then
        bb, lbl = makeTornadoBB(bbParent)
    end

    local conn = RunService.Heartbeat:Connect(function()
        if not storm.Parent then
            pcall(function() h:Destroy() end)
            pcall(function() if bb then bb:Destroy() end end)
            conn:Disconnect()
            ESPObjects[storm] = nil
            return
        end
        if not State.TornadoESP then return end

        local d = getTornadoData(storm)
        if not d then return end

        -- lazy-create billboard if center wasn't ready at addTornadoESP time
        if not bb and d.center then
            bb, lbl = makeTornadoBB(d.center)
        end

        local root = getRoot()
        local dist = root and math.floor((root.Position - d.pos).Magnitude) or 0
        local spd  = getMoveSpeed(storm, d.pos)
        local ef   = getEF(d.winds)
        local col  = EF_COLORS[ef] or EF_COLORS[-1]

        h.FillColor    = col
        h.OutlineColor = col
        if lbl then
            lbl.TextColor3 = col
            lbl.Text = string.format(
                "%s  |  %s  |  Vort: %d\nWinds: %d mph   Width: %d\nSpeed: %.1f s/s   Dist: %d studs",
                ef >= 0 and ("EF"..ef) or "PRE-TORNADO",
                d.otg and "ON GROUND" or "ALOFT",
                d.vort,
                math.floor(d.winds),
                math.floor(d.width),
                spd,
                dist
            )
        end
    end)

    ESPObjects[storm] = {type="tornado", h=h, bb=bb, conn=conn}
end

local function enableTornadoESP()
    local sf = Workspace:FindFirstChild("storm_related") and Workspace.storm_related:FindFirstChild("storms")
    if not sf then notify("Tornado ESP", "storm_related/storms not found!", 4); return end
    for _, s in ipairs(sf:GetChildren()) do addTornadoESP(s) end
    Connections.stormAdded = sf.ChildAdded:Connect(function(s)
        task.wait(0.5); if State.TornadoESP then addTornadoESP(s) end
    end)
end

local function disableTornadoESP()
    for k, v in pairs(ESPObjects) do
        if v.type == "tornado" then
            pcall(function() v.h:Destroy() end)
            pcall(function() if v.bb then v.bb:Destroy() end end)
            v.conn:Disconnect()
            ESPObjects[k] = nil
        end
    end
    if Connections.stormAdded then Connections.stormAdded:Disconnect(); Connections.stormAdded=nil end
end

