        local sf = Workspace:FindFirstChild("storm_related") and Workspace.storm_related:FindFirstChild("storms")
        if not sf then notify("Teleport","No storms folder.",3); return end
        local best, bestD = nil, math.huge
        for _, s in ipairs(sf:GetChildren()) do
            local d = getTornadoData(s)
            if d and d.otg then
                local dist = (root.Position - d.pos).Magnitude
                if dist < bestD then bestD=dist; best=d end
            end
        end
        if best then
            root.CFrame = CFrame.new(best.pos + Vector3.new(0,15,0))
            notify("Teleport","Teleported to tornado!",2)
        else
            notify("Teleport","No tornado on the ground right now.",3)
        end
    end
})

