local function getChar()  return LocalPlayer.Character end
local function getHum()   local c=getChar(); return c and c:FindFirstChildOfClass("Humanoid") end
local function getRoot()  local c=getChar(); return c and c:FindFirstChild("HumanoidRootPart") end
local function notify(t,c,d) Rayfield:Notify({Title=t,Content=c,Duration=d or 3,Image=4483362458}) end

local function getPlayerCar()
    local hum = getHum()
    if not hum or not hum.SeatPart then return nil end
    local seat  = hum.SeatPart
    local seats = seat.Parent
    local car   = seats and seats.Parent
    if car and car.Parent and car.Parent.Name == "cars" then return car end
    return nil
end

local function getEF(winds)
    if     winds >= 200 then return 5
    elseif winds >= 165 then return 4
    elseif winds >= 136 then return 3
    elseif winds >= 111 then return 2
    elseif winds >= 86  then return 1
    elseif winds >= 65  then return 0
    else                     return -1 end
end

local EF_COLORS = {
    [-1] = Color3.fromRGB(180,180,180),
    [0]  = Color3.fromRGB(0,  210,  0),
    [1]  = Color3.fromRGB(180,210,  0),
    [2]  = Color3.fromRGB(255,165,  0),
    [3]  = Color3.fromRGB(255,  0,  0),
    [4]  = Color3.fromRGB(180,  0,180),
    [5]  = Color3.fromRGB(100,  0,100),
}

local function getTornadoData(storm)
    local configs  = storm:FindFirstChild("configs")
    local tFolder  = configs and configs:FindFirstChild("tornado")
    if not tFolder then return nil end
    local windFolder = storm:FindFirstChild("wind")
    local center     = windFolder and windFolder:FindFirstChild("center")
    local pos        = center and center.Position
                    or (storm.PrimaryPart and storm.PrimaryPart.Position)
                    or Vector3.zero
    local function val(name)  local v=tFolder:FindFirstChild(name); return v and v.Value or 0     end
    local function bval(name) local v=tFolder:FindFirstChild(name); return v and v.Value or false  end
    return {
        winds     = val("winds"),
        otg       = bval("otg"),
        windfield = val("windfield"),
        width     = val("width"),
        vort      = val("vort_stability"),
        pos       = pos,
        center    = center,
    }
end

local function getMoveSpeed(storm, pos)
    local now  = tick()
    local prev = PrevPositions[storm]
    local speed = 0
    if prev then
        local dt = now - prev.t
        if dt > 0.1 then
            speed = (pos - prev.p).Magnitude / dt
            PrevPositions[storm] = {p=pos, t=now, spd=speed}
        else
            speed = prev.spd or 0
        end
    else
        PrevPositions[storm] = {p=pos, t=now, spd=0}
    end
    return math.floor(speed * 10) / 10
end

