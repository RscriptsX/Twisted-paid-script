-- Build player list (refreshed on open)
local function getPlayerNames()
    local names = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            table.insert(names, p.Name)
        end
    end
    if #names == 0 then names = {"No other players"} end
    return names
end

local playerDropdown = TabTeleport:CreateDropdown({
    Name           = "Select Player",
    Options        = getPlayerNames(),
    CurrentOption  = {getPlayerNames()[1]},
    MultipleOptions= false,
    Flag           = "TeleportTarget",
    Callback       = function(_) end,
})

TabTeleport:CreateButton({
    Name     = "Teleport to Player",
    Callback = function()
        local sel = Rayfield.Flags.TeleportTarget
        local target = sel and sel[1]
        if not target or target == "No other players" then
            notify("Teleport", "No player selected.", 3)
            return
        end
        local root = getRoot()
        local targetPlayer = Players:FindFirstChild(target)
        if root and targetPlayer and targetPlayer.Character then
            local tr = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
            if tr then
                root.CFrame = tr.CFrame + Vector3.new(0, 0, 3)
                notify("Teleport", "Teleported to " .. target, 3)
            end
        end
    end,
})

TabTeleport:CreateButton({
    Name     = "Refresh Player List",
    Callback = function()
        playerDropdown:Refresh(getPlayerNames(), false)
        notify("Teleport", "Player list refreshed.", 2)
    end,
})

