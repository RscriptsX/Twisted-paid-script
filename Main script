local function addPlayerESP(player)
    if player == LocalPlayer or ESPObjects[player] then return end
    local h
    local function attach(char)
        if h then h:Destroy() end
        if not State.PlayerESP then return end
        h = Instance.new("Highlight")
        h.FillColor = Color3.fromRGB(0,150,255)
        h.OutlineColor = Color3.fromRGB(0,100,220)
        h.FillTransparency = 0.4
        h.OutlineTransparency = 0
        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        h.Adornee = char
        h.Name = "RX_PlayerESP"
        h.Parent = game.CoreGui
    end
    if player.Character then attach(player.Character) end
    local conn = player.CharacterAdded:Connect(function(c) task.wait(0.5); attach(c) end)
    ESPObjects[player] = {
        type    = "player",
        destroy = function() if h then h:Destroy() end; conn:Disconnect() end
    }
end

local function enablePlayerESP()
    for _, p in ipairs(Players:GetPlayers()) do addPlayerESP(p) end
    Connections.plrAdded   = Players.PlayerAdded:Connect(function(p)
        task.wait(1); if State.PlayerESP then addPlayerESP(p) end
    end)
    Connections.plrRemoved = Players.PlayerRemoving:Connect(function(p)
        if ESPObjects[p] then ESPObjects[p].destroy(); ESPObjects[p]=nil end
    end)
end

local function disablePlayerESP()
    for _, p in ipairs(Players:GetPlayers()) do
        if ESPObjects[p] and ESPObjects[p].type=="player" then ESPObjects[p].destroy(); ESPObjects[p]=nil end
    end
    if Connections.plrAdded   then Connections.plrAdded:Disconnect();   Connections.plrAdded=nil   end
    if Connections.plrRemoved then Connections.plrRemoved:Disconnect(); Connections.plrRemoved=nil end
end

