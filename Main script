--  FLY
-- ============================================================
local flyBV, flyBG

local function enableFly()
    local root = getRoot()
    if not root then return end
    if flyBV and flyBV.Parent then flyBV:Destroy() end
    if flyBG and flyBG.Parent then flyBG:Destroy() end

    flyBV = Instance.new("BodyVelocity")
    flyBV.MaxForce = Vector3.new(1e9,1e9,1e9)
    flyBV.Velocity = Vector3.zero
    flyBV.Parent = root

    flyBG = Instance.new("BodyGyro")
    flyBG.MaxTorque = Vector3.new(1e9,1e9,1e9)
    flyBG.P = 1e6
    flyBG.CFrame = root.CFrame
    flyBG.Parent = root

    local hum = getHum()
    if hum then hum.PlatformStand = true end

    if Connections.fly then Connections.fly:Disconnect() end
    Connections.fly = RunService.Heartbeat:Connect(function()
        if not State.Fly then
            if flyBV and flyBV.Parent then flyBV:Destroy() end
            if flyBG and flyBG.Parent then flyBG:Destroy() end
            local h = getHum(); if h then h.PlatformStand = false end
            Connections.fly:Disconnect()
            return
        end
        local r = getRoot(); if not r then return end
        local cam = Workspace.CurrentCamera
        local spd = State.FlySpeed
        local vel = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W)         then vel += cam.CFrame.LookVector  * spd end
        if UserInputService:IsKeyDown(Enum.KeyCode.S)         then vel -= cam.CFrame.LookVector  * spd end
        if UserInputService:IsKeyDown(Enum.KeyCode.A)         then vel -= cam.CFrame.RightVector * spd end
        if UserInputService:IsKeyDown(Enum.KeyCode.D)         then vel += cam.CFrame.RightVector * spd end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space)     then vel += Vector3.new(0,spd,0)         end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then vel -= Vector3.new(0,spd,0)         end
        flyBV.Velocity = vel
        flyBG.CFrame   = cam.CFrame
    end)
end

-- ============================================================
--  CAR FLY
-- ============================================================
local function enableCarFly()
    if Connections.carFly then Connections.carFly:Disconnect() end
    Connections.carFly = RunService.Heartbeat:Connect(function()
        if not State.CarFly then
            -- clean up any leftover BodyVelocity
            local car = getPlayerCar()
            if car then
                local ch = car:FindFirstChild("chassis")
                if ch then local bv = ch:FindFirstChild("RX_CFV"); if bv then bv:Destroy() end end
            end
            Connections.carFly:Disconnect()
            return
        end
        local car = getPlayerCar(); if not car then return end
        local chassis = car:FindFirstChild("chassis"); if not chassis then return end

        local bv = chassis:FindFirstChild("RX_CFV")
        if not bv then
            bv = Instance.new("BodyVelocity")
            bv.Name = "RX_CFV"
            bv.MaxForce = Vector3.new(1e9,1e9,1e9)
            bv.Parent = chassis
        end

        local cam = Workspace.CurrentCamera
        local spd = State.FlySpeed * 2
        local vel = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W)         then vel += cam.CFrame.LookVector  * spd end
        if UserInputService:IsKeyDown(Enum.KeyCode.S)         then vel -= cam.CFrame.LookVector  * spd end
        if UserInputService:IsKeyDown(Enum.KeyCode.A)         then vel -= cam.CFrame.RightVector * spd end
        if UserInputService:IsKeyDown(Enum.KeyCode.D)         then vel += cam.CFrame.RightVector * spd end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space)     then vel += Vector3.new(0,spd,0)         end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then vel -= Vector3.new(0,spd,0)         end
        bv.Velocity = vel
    end)
end

-- ============================================================
--  CAR MODIFIERS  (engine / traction / body attributes)
-- ============================================================
local carModT = 0
Connections.carMods = RunService.Heartbeat:Connect(function(dt)
    carModT += dt
    if carModT < 0.25 then return end
    carModT = 0
    if not (State.CarSpeedMod or State.CarAccelMod or State.CarWindMod) then return end
    local car = getPlayerCar(); if not car then return end
    local mod = car:FindFirstChild("modifiers"); if not mod then return end
    if State.CarSpeedMod then mod:SetAttribute("engine",  State.CarSpeedVal) end
    if State.CarAccelMod then mod:SetAttribute("traction",State.CarAccelVal) end
    if State.CarWindMod  then mod:SetAttribute("body",    State.CarWindVal)  end
end)

