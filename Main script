TabTornado:CreateButton({Name = "Teleport to Nearest Tornado",
    Callback = function()
        local root = getRoot()
        if not root then return end
        local tornadoes = findTornadoes()
        local closest, dist = nil, math.huge
        for _, t in ipairs(tornadoes) do
            local primary = t:IsA("Model") and t.PrimaryPart or t
            if primary then
                local d = (root.Position - primary.Position).Magnitude
                if d < dist then dist = d; closest = primary end
            end
        end
        if closest then root.CFrame = CFrame.new(closest.Position + Vector3.new(0, 10, 0))
        notify("Teleport", "Teleported to tornado!", 2) else notify("Teleport", "No tornado found.", 2) end
    end})

