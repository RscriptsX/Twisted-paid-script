-- ============================================================
--  FLY  (LinearVelocity -- no PlatformStand, no anti-cheat kick)
-- ============================================================
local flyLV, flyAtt

local function cleanFly()
    if flyAtt and flyAtt.Parent then flyAtt:Destroy() end
    if flyLV  and flyLV.Parent  then flyLV:Destroy()  end
    flyAtt, flyLV = nil, nil
end

local function enableFly()
    cleanFly()
    local root = getRoot()
    if not root then return end

    flyAtt = Instance.new("Attachment")
    flyAtt.Name = "RX_FlyAtt"
    flyAtt.Parent = root

    flyLV = Instance.new("LinearVelocity")
    flyLV.Name = "RX_FlyLV"
    flyLV.Attachment0 = flyAtt
    flyLV.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector
    flyLV.VectorVelocity = Vector3.zero
    flyLV.MaxForce = 1e6
    flyLV.RelativeTo = Enum.ActuatorRelativeTo.World
    flyLV.Parent = root

    if Connections.fly then Connections.fly:Disconnect() end
    Connections.fly = RunService.Heartbeat:Connect(function()
        if not State.Fly then
            cleanFly()
            if Connections.fly then Connections.fly:Disconnect(); Connections.fly=nil end
            return
        end
        local r = getRoot()
        if not r or not flyLV or not flyLV.Parent then return end

        local cam = Workspace.CurrentCamera
        local spd = State.FlySpeed
        local vel = Vector3.zero
        local hasW = UserInputService:IsKeyDown(Enum.KeyCode.W)
        local hasS = UserInputService:IsKeyDown(Enum.KeyCode.S)
        local hasA = UserInputService:IsKeyDown(Enum.KeyCode.A)
        local hasD = UserInputService:IsKeyDown(Enum.KeyCode.D)
        local hasUp = UserInputService:IsKeyDown(Enum.KeyCode.Space)
        local hasDn = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift)

        if hasW then vel = vel + cam.CFrame.LookVector  * spd end
        if hasS then vel = vel - cam.CFrame.LookVector  * spd end
        if hasA then vel = vel - cam.CFrame.RightVector * spd end
        if hasD then vel = vel + cam.CFrame.RightVector * spd end
        if hasUp then vel = vel + Vector3.new(0, spd, 0)      end
        if hasDn then vel = vel - Vector3.new(0, spd, 0)      end

        -- hover when no vertical key
        if not hasUp and not hasDn then
            vel = Vector3.new(vel.X, 0, vel.Z)
        end

        flyLV.VectorVelocity = vel
    end)
end

-- ============================================================
--  CAR FLY  (LinearVelocity on chassis)
-- ============================================================
local carFlyAtt, carFlyLV

local function cleanCarFly()
    if carFlyAtt and carFlyAtt.Parent then carFlyAtt:Destroy() end
    if carFlyLV  and carFlyLV.Parent  then carFlyLV:Destroy()  end
    carFlyAtt, carFlyLV = nil, nil
end

local function enableCarFly()
    if Connections.carFly then Connections.carFly:Disconnect() end
    Connections.carFly = RunService.Heartbeat:Connect(function()
        if not State.CarFly then
            cleanCarFly()
            if Connections.carFly then Connections.carFly:Disconnect(); Connections.carFly=nil end
            return
        end
        local car = getPlayerCar()
        if not car then cleanCarFly(); return end
        local chassis = car:FindFirstChild("chassis")
        if not chassis then cleanCarFly(); return end

        -- (re)create constraint if chassis changed
        if not (carFlyLV and carFlyLV.Parent == chassis) then
            cleanCarFly()
            carFlyAtt = Instance.new("Attachment")
            carFlyAtt.Name = "RX_CFAtt"
            carFlyAtt.Parent = chassis

            carFlyLV = Instance.new("LinearVelocity")
            carFlyLV.Name = "RX_CFLV"
            carFlyLV.Attachment0 = carFlyAtt
            carFlyLV.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector
            carFlyLV.VectorVelocity = Vector3.zero
            carFlyLV.MaxForce = 5e6
            carFlyLV.RelativeTo = Enum.ActuatorRelativeTo.World
            carFlyLV.Parent = chassis
        end

        local cam = Workspace.CurrentCamera
        local spd = State.FlySpeed * 2
        local vel = Vector3.zero
        local hasUp = UserInputService:IsKeyDown(Enum.KeyCode.Space)
        local hasDn = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift)

        if UserInputService:IsKeyDown(Enum.KeyCode.W) then vel = vel + cam.CFrame.LookVector  * spd end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then vel = vel - cam.CFrame.LookVector  * spd end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then vel = vel - cam.CFrame.RightVector * spd end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then vel = vel + cam.CFrame.RightVector * spd end
        if hasUp then vel = vel + Vector3.new(0, spd, 0) end
        if hasDn then vel = vel - Vector3.new(0, spd, 0) end

        if not hasUp and not hasDn then
            vel = Vector3.new(vel.X, 0, vel.Z)
        end

        carFlyLV.VectorVelocity = vel
    end)
end

-- ============================================================
--  PLAYER INVINCIBILITY  (counter wind lift + auto-heal)
-- ============================================================
local function enablePlayerInvincible()
    if Connections.plrInvince then Connections.plrInvince:Disconnect() end
    Connections.plrInvince = RunService.Heartbeat:Connect(function()
        if not State.PlayerInvincible then
            if Connections.plrInvince then Connections.plrInvince:Disconnect(); Connections.plrInvince=nil end
            return
        end
        local hum  = getHum()
        local root = getRoot()
        if not hum or not root then return end

        -- full health always
        if hum.Health < hum.MaxHealth then
            hum.Health = hum.MaxHealth
        end

        -- cancel tornado-induced upward velocity
        local vel = root.AssemblyLinearVelocity
        if vel.Y > 8 then
            root.AssemblyLinearVelocity = Vector3.new(vel.X, 0, vel.Z)
        end
    end)
end

-- ============================================================
--  CAR INVINCIBILITY  (body modifier max + counter chassis lift)
-- ============================================================
local function enableCarInvincible()
    if Connections.carInvince then Connections.carInvince:Disconnect() end
    Connections.carInvince = RunService.Heartbeat:Connect(function()
        if not State.CarInvincible then
            -- restore body modifier to default when turned off
            local car = getPlayerCar()
            if car then
                local mod = car:FindFirstChild("modifiers")
                if mod then mod:SetAttribute("body", 100) end
            end
            if Connections.carInvince then Connections.carInvince:Disconnect(); Connections.carInvince=nil end
            return
        end
        local car = getPlayerCar()
        if not car then return end

        -- set wind threshold so high the tornado can never lift the car
        local mod = car:FindFirstChild("modifiers")
        if mod then
            mod:SetAttribute("body", 999999)
        end

        -- also physically counter any upward velocity being applied to chassis
        local chassis = car:FindFirstChild("chassis")
        if chassis then
            local vel = chassis.AssemblyLinearVelocity
            if vel.Y > 2 then
                chassis.AssemblyLinearVelocity = Vector3.new(vel.X, 0, vel.Z)
            end
        end
    end)
end

-- ============================================================
--  CAR MODIFIERS  (engine / traction / body attributes)
-- ============================================================
local carModT = 0
Connections.carMods = RunService.Heartbeat:Connect(function(dt)
    carModT = carModT + dt
    if carModT < 0.25 then return end
    carModT = 0
    if not (State.CarSpeedMod or State.CarAccelMod or State.CarWindMod) then return end
    local car = getPlayerCar(); if not car then return end
    local mod = car:FindFirstChild("modifiers"); if not mod then return end
    if State.CarSpeedMod then mod:SetAttribute("engine",   State.CarSpeedVal) end
    if State.CarAccelMod then mod:SetAttribute("traction", State.CarAccelVal) end
    -- CarInvincible overrides CarWindMod for the body attribute
    if State.CarWindMod and not State.CarInvincible then
        mod:SetAttribute("body", State.CarWindVal)
    end
end)

