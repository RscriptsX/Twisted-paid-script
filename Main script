-- ============================================================
--  PLAYER ESP
-- ============================================================
local function espColor(player)
    if player.Team then
        local tn = player.Team.Name:lower()
        if tn:find("monster") or tn:find("twisted") or tn:find("killer") then
            return Color3.fromRGB(255, 50, 50), Color3.fromRGB(255, 0, 0)
        end
    end
    return Color3.fromRGB(0, 150, 255), Color3.fromRGB(0, 100, 220)
end

local function makeHighlight(adornee, fill, outline)
    local h = Instance.new("Highlight")
    h.FillColor           = fill
    h.OutlineColor        = outline
    h.FillTransparency    = 0.45
    h.OutlineTransparency = 0
    h.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
    h.Adornee             = adornee
    h.Parent              = game.CoreGui
    return h
end

local function addPlayerESP(player)
    if player == LocalPlayer or ESPObjects[player] then return end
    local fill, outline = espColor(player)
    local h

    local function attach(char)
        if h then h:Destroy() end
        if State.PlayerESP then
            h = makeHighlight(char, fill, outline)
            h.Name = "RX_PlayerESP"
        end
    end

    if player.Character then attach(player.Character) end
    local conn = player.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        fill, outline = espColor(player)
        attach(char)
    end)

    ESPObjects[player] = {
        destroy = function()
            if h then h:Destroy() end
            conn:Disconnect()
        end
    }
end

local function removePlayerESP(player)
    if ESPObjects[player] then
        ESPObjects[player].destroy()
        ESPObjects[player] = nil
    end
end

local function enablePlayerESP()
    for _, p in ipairs(Players:GetPlayers()) do addPlayerESP(p) end
    Connections.espAdded = Players.PlayerAdded:Connect(function(p)
        task.wait(1)
        if State.PlayerESP then addPlayerESP(p) end
    end)
    Connections.espRemoved = Players.PlayerRemoving:Connect(removePlayerESP)
end

local function disablePlayerESP()
    for _, p in ipairs(Players:GetPlayers()) do removePlayerESP(p) end
    if Connections.espAdded   then Connections.espAdded:Disconnect();   Connections.espAdded   = nil end
    if Connections.espRemoved then Connections.espRemoved:Disconnect(); Connections.espRemoved = nil end
end

-- ============================================================
--  MONSTER ESP
-- ============================================================
local MONSTER_FOLDERS = {"Monsters","Monster","Entities","Entity","Enemies","Enemy","Killers","Twisted"}

local function enableMonsterESP()
    for _, name in ipairs(MONSTER_FOLDERS) do
        local folder = Workspace:FindFirstChild(name)
        if folder then
            for _, model in ipairs(folder:GetChildren()) do
                if model:IsA("Model") then
                    local h = makeHighlight(model, Color3.fromRGB(255, 40, 40), Color3.fromRGB(200, 0, 0))
                    h.FillTransparency = 0.3
                    h.Name = "RX_MonsterESP"
                end
            end
        end
    end
end

local function disableMonsterESP()
    for _, v in ipairs(game.CoreGui:GetChildren()) do
        if v.Name == "RX_MonsterESP" then v:Destroy() end
    end
end

-- ============================================================
--  ITEM ESP
-- ============================================================
local ITEM_FOLDERS = {"Items","Batteries","Collectibles","Pickups","Objects","Interactables","Props"}

local function enableItemESP()
    for _, name in ipairs(ITEM_FOLDERS) do
        local folder = Workspace:FindFirstChild(name)
        if folder then
            for _, obj in ipairs(folder:GetChildren()) do
                local part = obj:IsA("BasePart") and obj or obj:FindFirstChildOfClass("BasePart")
                if part then
                    local h = makeHighlight(
                        obj:IsA("Model") and obj or part,
                        Color3.fromRGB(255, 220, 0),
                        Color3.fromRGB(200, 170, 0)
                    )
                    h.Name = "RX_ItemESP"
                end
            end
        end
    end
end

local function disableItemESP()
    for _, v in ipairs(game.CoreGui:GetChildren()) do
        if v.Name == "RX_ItemESP" then v:Destroy() end
    end
end

-- ============================================================
--  FULLBRIGHT
-- ============================================================
local function setFullbright(on)
    if on then
        Lighting.Brightness     = 2
        Lighting.ClockTime      = 14
        Lighting.FogEnd         = 100000
        Lighting.GlobalShadows  = false
        Lighting.Ambient        = Color3.fromRGB(178, 178, 178)
        Lighting.OutdoorAmbient = Color3.fromRGB(178, 178, 178)
    else
        Lighting.Brightness     = State.OrigBrightness
        Lighting.ClockTime      = State.OrigClockTime
        Lighting.FogEnd         = State.OrigFogEnd
        Lighting.GlobalShadows  = State.OrigGlobalShadows
        Lighting.Ambient        = State.OrigAmbient
        Lighting.OutdoorAmbient = State.OrigOutdoorAmbient
    end
end

-- ============================================================
--  AUTO-COLLECT
-- ============================================================
local function tryCollect()
    local root = getRoot()
    if not root then return end
    for _, folderName in ipairs(ITEM_FOLDERS) do
        local folder = Workspace:FindFirstChild(folderName)
        if folder then
            for _, obj in ipairs(folder:GetChildren()) do
                local part = obj:IsA("BasePart") and obj or obj:FindFirstChildOfClass("BasePart")
                if part and (root.Position - part.Position).Magnitude < 80 then
                    for _, remote in ipairs(ReplicatedStorage:GetDescendants()) do
                        if remote:IsA("RemoteEvent") then
                            local n = remote.Name:lower()
                            if n:find("collect") or n:find("pickup") or n:find("grab") or n:find("battery") then
                                pcall(function() remote:FireServer(obj) end)
                            end
                        end
                    end
                    root.CFrame = CFrame.new(part.Position + Vector3.new(0, 4, 0))
                    task.wait(0.05)
                end
            end
        end
    end
end

-- ============================================================
--  RUNTIME LOOPS
-- ============================================================
Connections.heartbeat = RunService.Heartbeat:Connect(function()
    local hum  = getHum()
    local root = getRoot()
    local char = getChar()

    if State.SpeedHack and hum and hum.WalkSpeed ~= State.SpeedValue then
        hum.WalkSpeed = State.SpeedValue
    end

    if State.JumpHack and hum and hum.JumpPower ~= State.JumpValue then
        hum.JumpPower = State.JumpValue
    end

    if State.GodMode and hum then
        hum.MaxHealth = math.huge
        hum.Health    = math.huge
    end

    if State.InfiniteStamina and char then
        for _, v in ipairs(char:GetDescendants()) do
            if v:IsA("NumberValue") then
                local n = v.Name:lower()
                if n:find("stamina") or n:find("energy") or n:find("sprint") then
                    v.Value = v.MaxValue or 100
                end
            end
        end
    end

    if State.AntiTrap and root and hum then
        if root.Velocity.Magnitude < 0.3 and hum.MoveDirection.Magnitude > 0.1 then
            hum.Jump = true
        end
    end
end)

Connections.stepped = RunService.Stepped:Connect(function()
    if not State.Noclip then return end
    local char = getChar()
    if char then
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = false end
        end
    end
end)

local lastCollect = 0
Connections.collectLoop = RunService.Heartbeat:Connect(function()
    if not State.AutoCollect then return end
    local now = tick()
    if now - lastCollect >= 0.3 then
        lastCollect = now
        pcall(tryCollect)
    end
end)

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.5)
    local hum = getHum()
    if not hum then return end
    if State.SpeedHack then hum.WalkSpeed = State.SpeedValue end
    if State.JumpHack  then hum.JumpPower = State.JumpValue  end
    if State.GodMode   then hum.MaxHealth = math.huge; hum.Health = math.huge end
end)

